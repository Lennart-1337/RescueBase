# Server deploys consume this file through the GHCR-backed production deploy script.
NODE_ENV=production
APP_DOMAIN=rescuebase.example.org
APP_PUBLIC_URL=https://rescuebase.example.org

MARIADB_DATABASE=rescuebase
MARIADB_USER=rescuebase
MARIADB_PASSWORD=change-me
MARIADB_ROOT_PASSWORD=change-me-root

JWT_SECRET=change-me
API_PORT=3000
RESEND_API_KEY=re_live_replace_me
RESEND_FROM=RescueBase <noreply@example.org>
RESCUEBASE_SEED_DEV_DATA=false
BACKUP_AGE_RECIPIENT=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.org

API_IMAGE=ghcr.io/example/rescuebase-api
WEB_IMAGE=ghcr.io/example/rescuebase-web
IMAGE_TAG=production-latest

CLOUDFLARE_ORIGIN_CERT_HOST_FILE=/opt/rescuebase/certs/origin-cert.pem
CLOUDFLARE_ORIGIN_KEY_HOST_FILE=/opt/rescuebase/certs/origin-key.pem
