{
  "name": "@rescuebase/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nest start --watch",
    "prebuild": "npm run build -w @rescuebase/domain && npm run prisma:generate",
    "build": "nest build",
    "generate:openapi": "npm run build && node dist/openapi/write-document.js",
    "start": "node dist/main.js",
    "pretest": "npm run prisma:generate",
    "test": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config jest.config.cjs",
    "lint": "eslint src test --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "npm run prisma:generate && node dist/persistence/seed-cli.js",
    "prisma:seed:dev": "npm run prisma:generate && node --loader ts-node/esm prisma/seed.ts",
    "vapid:generate": "web-push generate-vapid-keys"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/swagger": "^11.4.5",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@rescuebase/domain": "file:../../packages/domain",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.2",
    "npm": "^12.0.1",
    "otplib": "^13.4.1",
    "pdfkit": "^0.19.1",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.24",
    "@nestjs/testing": "^11.1.27",
    "@testcontainers/mysql": "^12.0.4",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.5",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.1",
    "@types/pdfkit": "^0.17.3",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "@types/web-push": "^3.6.4",
    "jest": "^30.2.0",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "testcontainers": "^12.0.4",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2"
  }
}
