generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  WAREHOUSE
}

enum KitOperationalStatus {
  READY
  CONDITIONAL
  NOT_READY
}

enum ReplenishmentStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum InventoryProcurementStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum PurchaseOrderStatus {
  DRAFT
  APPROVED
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
}

enum AuditActorType {
  SYSTEM
  USER
  PUBLIC_CHECKER
}

enum TwoFactorMethod {
  TOTP
  EMAIL
}

enum AlertCategory {
  EXPIRY
  STK_DUE
  MTK_DUE
}

enum NotificationTemplateKey {
  ALERT_IMMEDIATE
  ALERT_DIGEST
  NEW_ORDER
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  displayName      String
  passwordHash     String?
  role             UserRole
  twoFactorSecret  String?
  twoFactorEnabled Boolean  @default(false)
  twoFactorMethod  TwoFactorMethod?
  newOrderNotificationsEnabled Boolean @default(false)
  active           Boolean  @default(true)
  sessions         UserSession[]
  invitations      UserInvitation[]
  passwordResets   PasswordResetToken[]
  emailChallenges  EmailTwoFactorChallenge[]
  pendingLogins    PendingLoginChallenge[]
  alertSubscriptions AlertSubscription[]
  approvedPurchaseOrders PurchaseOrder[] @relation("PurchaseOrderApprovedBy")
  deletedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([deletedAt])
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model UserInvitation {
  id         String   @id @default(cuid())
  userId      String
  tokenHash   String   @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId      String
  tokenHash   String   @unique
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model EmailTwoFactorChallenge {
  id         String   @id @default(cuid())
  userId      String
  codeHash    String
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model PendingLoginChallenge {
  id               String          @id @default(cuid())
  userId           String
  tokenHash        String          @unique
  method           TwoFactorMethod
  emailChallengeId String?
  expiresAt        DateTime
  consumedAt       DateTime?
  createdAt        DateTime        @default(now())
  user             User            @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model Location {
  id        String   @id @default(cuid())
  name      String
  kind      String
  batches   Batch[]
  kits      Kit[]
  inventoryTargets InventoryTarget[]
  procurementOrders InventoryProcurementOrder[]
  purchaseOrders PurchaseOrder[]
  medicalDevices MedicalDevice[]
  alertSubscriptions AlertSubscription[]
  alertEvents AlertEvent[]
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deletedAt])
}

model Article {
  id                    String             @id @default(cuid())
  name                  String
  sortOrder             Int                @default(0)
  unit                  String
  manufacturer          String?
  manufacturerPartNumber String?
  category              String?
  barcode               String?
  articleUrl            String?
  defaultSupplierName   String?
  defaultGrossPriceCents Int?
  sterile               Boolean            @default(false)
  medicalDevice         Boolean            @default(false)
  stkRequired           Boolean            @default(false)
  stkIntervalMonths     Int?
  mtkRequired           Boolean            @default(false)
  mtkIntervalMonths     Int?
  storageNotes         String?            @db.Text
  notes                String?            @db.Text
  criticalDefault      Boolean            @default(false)
  batches              Batch[]
  inventoryTargets     InventoryTarget[]
  procurementOrders    InventoryProcurementOrder[]
  purchaseOrderLines   PurchaseOrderLine[]
  medicalDevices       MedicalDevice[]
  templateItems        TemplatePosition[]
  deletedAt            DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([deletedAt])
}

model Batch {
  id         String   @id @default(cuid())
  articleId  String
  locationId String
  lotNumber  String
  expiresAt  DateTime
  quantity   Int
  article    Article  @relation(fields: [articleId], references: [id])
  location   Location @relation(fields: [locationId], references: [id])
  movements  InventoryMovement[]
  procurementReceipts InventoryProcurementReceipt[]
  purchaseOrderReceipts PurchaseOrderReceipt[]
  deletedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([articleId, expiresAt])
  @@index([locationId])
  @@index([deletedAt])
}

model InventoryTarget {
  id             String   @id @default(cuid())
  articleId      String
  locationId     String
  targetQuantity Int
  article        Article  @relation(fields: [articleId], references: [id])
  location       Location @relation(fields: [locationId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([articleId, locationId])
  @@index([locationId])
}

model InventoryProcurementOrder {
  id                 String                     @id @default(cuid())
  articleId          String
  locationId         String
  status             InventoryProcurementStatus @default(OPEN)
  requestedQuantity  Int
  receivedQuantity   Int                        @default(0)
  articleUrlSnapshot String?
  activeKey          String?                    @unique
  article            Article                    @relation(fields: [articleId], references: [id])
  location           Location                   @relation(fields: [locationId], references: [id])
  receipts           InventoryProcurementReceipt[]
  movements          InventoryMovement[]
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  @@index([articleId, locationId, status])
  @@index([locationId])
}

model InventoryProcurementReceipt {
  id                 String                    @id @default(cuid())
  orderId            String
  batchId            String
  quantity           Int
  lotNumber          String
  expiresAt          DateTime
  verifiedAt         DateTime
  verifiedBy         String
  order              InventoryProcurementOrder @relation(fields: [orderId], references: [id])
  batch              Batch                     @relation(fields: [batchId], references: [id])
  createdAt          DateTime                  @default(now())

  @@index([orderId])
  @@index([batchId])
}

model PurchaseOrder {
  id               String              @id @default(cuid())
  orderNumber      String              @unique
  supplierName     String
  locationId       String
  status           PurchaseOrderStatus @default(DRAFT)
  notes            String?             @db.Text
  archivedAt       DateTime?
  approvedAt       DateTime?
  approvedByUserId String?
  approvedByName   String?
  orderedAt        DateTime?
  receivedAt       DateTime?
  location         Location            @relation(fields: [locationId], references: [id])
  approvedBy       User?               @relation("PurchaseOrderApprovedBy", fields: [approvedByUserId], references: [id])
  lines            PurchaseOrderLine[]
  receipts         PurchaseOrderReceipt[]
  movements        InventoryMovement[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([status, updatedAt])
  @@index([archivedAt, updatedAt])
  @@index([locationId])
  @@index([approvedByUserId])
}

model PurchaseOrderLine {
  id                             String                 @id @default(cuid())
  orderId                        String
  articleId                      String
  articleNameSnapshot            String
  supplierArticleNumberSnapshot  String?
  articleUrlSnapshot             String?
  manufacturerPartNumberSnapshot String?
  unitSnapshot                   String
  grossUnitPriceCents            Int
  orderedQuantity                Int
  receivedQuantity               Int                    @default(0)
  note                           String?                @db.Text
  order                          PurchaseOrder          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  article                        Article                @relation(fields: [articleId], references: [id])
  receipts                       PurchaseOrderReceipt[]
  createdAt                      DateTime               @default(now())
  updatedAt                      DateTime               @updatedAt

  @@index([orderId])
  @@index([articleId])
}

model PurchaseOrderReceipt {
  id         String            @id @default(cuid())
  orderId    String
  lineId     String
  batchId    String
  quantity   Int
  lotNumber  String
  expiresAt  DateTime
  receivedAt DateTime
  receivedBy String
  order      PurchaseOrder     @relation(fields: [orderId], references: [id])
  line       PurchaseOrderLine @relation(fields: [lineId], references: [id])
  batch      Batch             @relation(fields: [batchId], references: [id])
  createdAt  DateTime          @default(now())

  @@index([orderId])
  @@index([lineId])
  @@index([batchId])
}

model KitTemplate {
  id        String             @id @default(cuid())
  name      String
  version   Int
  positions TemplatePosition[]
  kits      Kit[]
  deletedAt DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@unique([name, version])
  @@index([deletedAt])
}

model TemplatePosition {
  id               String      @id @default(cuid())
  templateId       String
  articleId        String
  sortOrder        Int         @default(0)
  moduleName       String?
  requiredQuantity Int
  critical         Boolean     @default(false)
  template         KitTemplate @relation(fields: [templateId], references: [id])
  article          Article     @relation(fields: [articleId], references: [id])
}

model Kit {
  id             String               @id @default(cuid())
  name           String
  code           String               @unique
  locationId     String
  templateId     String
  status         KitOperationalStatus @default(READY)
  publicToken    String               @unique
  tokenRotatedAt DateTime             @default(now())
  location       Location             @relation(fields: [locationId], references: [id])
  template       KitTemplate          @relation(fields: [templateId], references: [id])
  medicalDevices MedicalDevice[]
  checks         Check[]
  orders         ReplenishmentOrder[]
  deletedAt      DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([deletedAt])
}

model Check {
  id                  String               @id @default(cuid())
  kitId               String
  checkerName         String
  selectedStatus      KitOperationalStatus
  effectiveStatus     KitOperationalStatus
  statusReason        String?
  warningsJson        Json
  signaturePngDataUrl String               @db.LongText
  signatureHash       String
  kit                 Kit                  @relation(fields: [kitId], references: [id])
  positions           CheckPosition[]
  order               ReplenishmentOrder?
  createdAt           DateTime             @default(now())
}

model CheckPosition {
  id                       String @id @default(cuid())
  checkId                  String
  templatePositionId       String
  articleId                String
  articleName              String
  moduleName               String?
  unit                     String
  requiredQuantity         Int
  countedQuantity          Int
  discardedExpiredQuantity Int
  missingQuantity          Int
  surplusQuantity          Int
  critical                 Boolean
  note                     String?
  check                    Check  @relation(fields: [checkId], references: [id])

  @@index([checkId])
}

model ReplenishmentOrder {
  id        String                @id @default(cuid())
  kitId     String
  checkId   String                @unique
  status    ReplenishmentStatus   @default(OPEN)
  kit       Kit                   @relation(fields: [kitId], references: [id])
  check     Check                 @relation(fields: [checkId], references: [id])
  items     ReplenishmentItem[]
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
}

model ReplenishmentItem {
  id                   String             @id @default(cuid())
  orderId              String
  articleId            String
  articleName          String
  templatePositionId   String
  requestedQuantity    Int
  fulfilledQuantity    Int                @default(0)
  reason               String
  unit                 String
  critical             Boolean            @default(false)
  order                ReplenishmentOrder @relation(fields: [orderId], references: [id])
}

model InventoryMovement {
  id                   String   @id @default(cuid())
  batchId              String
  articleId            String
  locationId           String
  replenishmentOrderId String?
  inventoryProcurementOrderId String?
  purchaseOrderId      String?
  templatePositionId   String?
  type                 String
  quantity             Int
  actorLabel           String
  reason               String?
  metadata             Json?
  createdAt            DateTime @default(now())
  batch                Batch    @relation(fields: [batchId], references: [id])
  inventoryProcurementOrder InventoryProcurementOrder? @relation(fields: [inventoryProcurementOrderId], references: [id])
  purchaseOrder        PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  @@index([batchId])
  @@index([replenishmentOrderId])
  @@index([inventoryProcurementOrderId])
  @@index([purchaseOrderId])
}

model InventoryAutomationConfig {
  id                 String    @id @default("singleton")
  enabled            Boolean   @default(true)
  dailyReconcileTime String    @default("02:00")
  lastReconciledAt   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model AppSettings {
  id                                      String   @id @default("singleton")
  appName                                 String   @default("RescueBase")
  appSubtitle                             String   @default("Sanitätslager")
  showLogo                                Boolean  @default(true)
  showAppName                             Boolean  @default(false)
  showAppSubtitle                         Boolean  @default(true)
  timezone                                String   @default("UTC")
  newUserOrderNotificationsDefaultEnabled Boolean @default(false)
  createdAt                               DateTime @default(now())
  updatedAt                               DateTime @updatedAt
}

model AlertAutomationConfig {
  id                 String    @id @default("singleton")
  dailyDigestEnabled Boolean   @default(true)
  dailyDigestTime    String    @default("06:00")
  warningWindowDays  Int       @default(90)
  lastDigestSentAt   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model NotificationTemplate {
  key             NotificationTemplateKey @id
  subjectTemplate String
  introTemplate   String                  @db.Text
  bodyTemplate    String                  @db.Text
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
}

model AuditEvent {
  id         String         @id @default(cuid())
  actorType  AuditActorType
  actorLabel String
  action     String
  entityType String
  entityId   String
  payload    Json
  createdAt  DateTime       @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

model MedicalDevice {
  id                String   @id @default(cuid())
  articleId         String
  locationId        String
  kitId             String?
  name              String
  serialNumber      String?
  inventoryNumber   String?
  lastStkAt         DateTime?
  lastMtkAt         DateTime?
  stkIntervalMonths Int?
  mtkIntervalMonths Int?
  active            Boolean  @default(true)
  notes             String?  @db.Text
  article           Article  @relation(fields: [articleId], references: [id])
  location          Location @relation(fields: [locationId], references: [id])
  kit               Kit?     @relation(fields: [kitId], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([articleId])
  @@index([kitId])
  @@index([locationId])
}

model AlertSubscription {
  id         String      @id @default(cuid())
  userId     String
  category   AlertCategory
  locationId String?
  user       User        @relation(fields: [userId], references: [id])
  location   Location?   @relation(fields: [locationId], references: [id])
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([userId])
  @@index([category, locationId])
}

model AlertEvent {
  id                  String        @id @default(cuid())
  category            AlertCategory
  sourceType          String
  sourceId            String
  locationId          String?
  location            Location?     @relation(fields: [locationId], references: [id])
  title               String
  details             String        @db.Text
  dueAt               DateTime?
  firstSeenAt         DateTime
  lastSeenAt          DateTime
  resolvedAt          DateTime?
  lastImmediateSentAt DateTime?
  lastDigestSentAt    DateTime?
  metadata            Json?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@unique([category, sourceType, sourceId])
  @@index([category, locationId])
  @@index([resolvedAt])
}
