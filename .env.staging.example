# Server deploys consume this file through the GHCR-backed staging deploy script.
APP_DOMAIN=staging.rescuebase.example.org
APP_PUBLIC_URL=https://staging.rescuebase.example.org
CLOUDFLARE_ORIGIN_CERT_HOST_FILE=/opt/rescuebase/staging/certs/origin-cert.pem
CLOUDFLARE_ORIGIN_KEY_HOST_FILE=/opt/rescuebase/staging/certs/origin-key.pem
JWT_SECRET=replace-with-a-long-random-secret
API_IMAGE=ghcr.io/example-org/rescuebase-api
WEB_IMAGE=ghcr.io/example-org/rescuebase-web
IMAGE_TAG=staging-latest
MARIADB_DATABASE=rescuebase
MARIADB_USER=rescuebase
MARIADB_PASSWORD=replace-with-a-strong-password
RESEND_API_KEY=re_live_replace_me
RESEND_FROM=RescueBase Staging <noreply@example.org>
BACKUP_AGE_RECIPIENT=
AGE_IDENTITY_HOST_FILE=./keys/restore-disabled.txt
AGE_IDENTITY_FILE=/run/secrets/staging.agekey
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.org
