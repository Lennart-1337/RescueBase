{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Web (Vite)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:web"],
      "port": 5173
    },
    {
      "name": "API (NestJS)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:api"],
      "port": 3000
    },
    {
      "name": "Datenbank (MariaDB via Docker)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "-d", "mariadb"],
      "port": 3306
    }
  ]
}
